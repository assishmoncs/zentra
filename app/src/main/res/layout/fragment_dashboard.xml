<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Permission Screen -->
        <LinearLayout
            android:id="@+id/layoutPermission"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher_foreground"
                android:layout_marginBottom="32dp"
                app:tint="@color/accent"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/permission_title"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/permission_description"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/permission_instruction"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="48dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantPermission"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/grant_access"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark" />

        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.4"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="40dp" />

            <!-- Score Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_placeholder"
                        android:textSize="80sp"
                        android:fontFamily="sans-serif-light"
                        android:textColor="@color/score_high"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/life_score_label"
                        android:textSize="13sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/tvFeedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvGoalStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/goal_label"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Focus Session Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_session_title"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvFocusTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_session_timer_placeholder"
                        android:textSize="48sp"
                        android:fontFamily="sans-serif-light"
                        android:textColor="@color/text_primary"
                        android:includeFontPadding="false"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFocusToggle"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_session_start"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Weekly Trends Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weekly_trends_title"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvWeeklyAvgScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/weekly_avg_score"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvWeeklyTotalTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/weekly_total_time"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Usage Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTotalTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/screen_time_today"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="20dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/top_apps_today"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvApp1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvApp2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvApp3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvNoApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_usage_data"
                        android:textSize="14sp"
                        android:textColor="@color/text_tertiary"
                        android:paddingTop="8dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/retry"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/accent_soft"
                android:textColor="@color/accent"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:visibility="gone" />

        </LinearLayout>

    </FrameLayout>
</ScrollView>
